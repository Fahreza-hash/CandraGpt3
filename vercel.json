{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/js/(.*)",        "dest": "/public/js/$1"         },
    { "src": "/styles.css",     "dest": "/public/styles.css"    },
    { "src": "/api/auth/(.*)", "dest": "/api/index.js"         },
    { "src": "/api/user/(.*)", "dest": "/api/index.js"         },
    { "src": "/api/chat/(.*)", "dest": "/api/index.js"         },
    { "src": "/api/ping",      "dest": "/api/index.js"         },
    { "src": "/login",         "dest": "/public/login.html"    },
    { "src": "/register",      "dest": "/public/register.html" },
    { "src": "/home",          "dest": "/public/home.html"     },
    { "src": "/chat/(.*)",     "dest": "/public/home.html"     },
    { "src": "/",              "dest": "/public/login.html"    }
  ]
}
